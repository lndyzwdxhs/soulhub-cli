{
  "name": "soulhubcli",
  "version": "1.0.17",
  "description": "SoulHub CLI - Install and manage AI agent persona templates for OpenClaw",
  "type": "module",
  "bin": {
    "soulhub": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "soulhub",
    "agent",
    "ai",
    "openclaw",
    "cli",
    "persona",
    "template"
  ],
  "author": "soulhub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lndyzwdxhs/soulhub-cli.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "node-fetch": "^3.3.2",
    "tar": "^7.5.11"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@yao-pkg/pkg": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "pkg": {
    "targets": [
      "node20"
    ],
    "outputPath": "bin"
  }
}
